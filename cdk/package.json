{
  "name": "clean-architecture-cdk",
  "version": "0.1.0",
  "bin": {
    "clean-architecture-cdk": "bin/cdk-app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth": "cdk synth",
    "synth:dev": "cdk synth -c env=dev",
    "synth:stg": "cdk synth -c env=stg",
    "synth:prd": "cdk synth -c env=prd",
    "deploy": "cdk deploy",
    "deploy:dev": "cdk deploy -c env=dev",
    "deploy:stg": "cdk deploy -c env=stg",
    "deploy:prd": "cdk deploy -c env=prd --require-approval broadening",
    "destroy": "cdk destroy",
    "destroy:dev": "cdk destroy -c env=dev",
    "destroy:stg": "cdk destroy -c env=stg",
    "sam:synth": "cdk synth -c env=local --no-staging",
    "sam:api": "sam local start-api -t cdk.out/CleanArchStack-local.template.json --docker-network host",
    "sam:api:debug": "sam local start-api -t cdk.out/CleanArchStack-local.template.json --docker-network host --debug",
    "sam:invoke:register": "sam local invoke RegisterUserFunction -t cdk.out/CleanArchStack-local.template.json -e events/register-user.json",
    "sam:invoke:getuser": "sam local invoke GetUserFunction -t cdk.out/CleanArchStack-local.template.json -e events/get-user.json",
    "sam:invoke:createorder": "sam local invoke CreateOrderFunction -t cdk.out/CleanArchStack-local.template.json -e events/create-order.json",
    "diff": "cdk diff",
    "diff:dev": "cdk diff -c env=dev",
    "diff:stg": "cdk diff -c env=stg",
    "diff:prd": "cdk diff -c env=prd"
  },
  "devDependencies": {
    "@types/node": "20.1.0",
    "aws-cdk": "^2.114.0",
    "esbuild": "^0.18.0",
    "ts-node": "^10.9.1",
    "typescript": "~5.1.3"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.948.0",
    "@aws-sdk/lib-dynamodb": "^3.948.0",
    "aws-cdk-lib": "^2.114.0",
    "constructs": "^10.0.0"
  }
}