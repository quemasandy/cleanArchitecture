{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SAM: Debug Lambda",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 5858,
      "localRoot": "${workspaceFolder}/src",
      "remoteRoot": "/var/task",
      "protocol": "inspector",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "registerUser",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${workspaceFolder}/scripts/registerUser.ts"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "env": {
        "USERS_TABLE": "users-local",
        "DYNAMODB_ENDPOINT": "http://localhost:8000"
      }
    },
    {
      "name": "loginUser",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${workspaceFolder}/scripts/loginUser.ts"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "env": {
        "USERS_TABLE": "users-local",
        "DYNAMODB_ENDPOINT": "http://localhost:8000"
      }
    },
    {
      "name": "logoutUser",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${workspaceFolder}/scripts/logoutUser.ts"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "env": {
        "USERS_TABLE": "users-local",
        "DYNAMODB_ENDPOINT": "http://localhost:8000"
      }
    }
  ]
}