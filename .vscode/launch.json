{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SAM: Debug Lambda",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 5858,
      "localRoot": "${workspaceFolder}/src",
      "remoteRoot": "/var/task",
      "protocol": "inspector",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "TS: Debug Local (Sin Docker)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${workspaceFolder}/scripts/local-run.ts"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ]
    }
  ]
}